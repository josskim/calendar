generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Pension {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  customDomain String?  @unique
  logoUrl      String?
  themeConfig  Json?    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rooms        Room[]
  reservations reservation[]
  admins       admin[]

  @@map("pensions")
}

model Room {
  id           String   @id @default(cuid())
  pensionId    String
  pension      Pension  @relation(fields: [pensionId], references: [id])
  name         String
  description  String?
  basePrice    Int
  maxPeople    Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  images       Image[]
  reservations reservation[]

  @@map("rooms")
}

model Image {
  id        String   @id @default(cuid())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id])
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("images")
}

model reservation {
  id             BigInt   @id @default(autoincrement())
  pensionId      String?
  pension        Pension? @relation(fields: [pensionId], references: [id])
  roomId         String?
  room           Room?    @relation(fields: [roomId], references: [id])
  
  type           String
  category       String
  use_date       DateTime
  nights         Int
  quantity       Int
  guest_name     String
  phone          String
  people_count   Int
  user_type      String
  total_amount   Int
  extra_amount   Int      @default(0)
  payment_status String
  deposit_date   DateTime
  cancel_date    DateTime
  source         String
  memo           String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("reservations")
}

model admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  pensionId String?
  pension   Pension? @relation(fields: [pensionId], references: [id])
  createdAt DateTime @default(now())

  @@map("admins")
}

model holiday {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique
  name      String
  source    String   @default("custom")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("holidays")
}
